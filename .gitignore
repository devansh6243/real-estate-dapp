# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Custom Root Scratch Files
/*.ps1
/*.txt
/*.docx
/*.js
!/hardhat.config.js
!/postcss.config.js
/*.html
/*.zip
/*.mmd
/toc_items.json
/*.xml
!/BBREMS_Final_Report.docx
!/Patent_Report.docx
!/Indian_Patent_Report_Final.docx

# Custom Extraction Caches
/cache/
/extract_docx/
/extracted_docx/
